generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Thesis {
  id         Int      @id @default(autoincrement())
  author     String   @db.VarChar(255)
  year       Int
  title      String   @db.Text
  type       String?  @db.VarChar(100)
  university String?  @db.VarChar(255)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model YoutubeVideo {
  id              String   @id @db.VarChar(50) // Menggunakan ID asli dari Youtube (contoh: dQw4w9WgXcQ)
  title           String   @db.Text
  thumbnail       String?  @db.Text
  channel         String   @db.VarChar(255)
  view_count      Int      @default(0)
  like_count      Int      @default(0)
  upload_date     String?  @db.VarChar(20)
  duration_string String?  @db.VarChar(20)
  webpage_url     String   @db.Text
  author          String?  @db.VarChar(255)
  nim             String?  @db.VarChar(50)
  academic_year   Int?
  thesis_type     String?  @db.VarChar(100)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
